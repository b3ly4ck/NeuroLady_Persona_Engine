# NeuroLady — environment configuration TEMPLATE.
# Copy this file to `.env` and fill in real values. `.env` is git-ignored and
# must NEVER be committed. Do not put real secrets in this template file.

# ── Telegram ──────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────
# Dev default is a local SQLite file; use a Postgres URL in production.
DATABASE_URL=sqlite+aiosqlite:///./neurolady.sqlite3

# ── Chat LLM runner (F-002+, not needed for F-001 onboarding) ─────────────
# OpenAI-compatible endpoint exposed by the local chat model runner (chat/serve.py).
# Base only — the client appends /v1/chat/completions. Default matches chat/serve.py.
CHAT_BASE_URL=http://127.0.0.1:8080

# ── Semantic memory (F-004 vector half) ──────────────────────────────────
# Qdrant location: a URL (http://host:6333), a local dir path (embedded, dev), or ":memory:".
# Empty disables semantic recall → the memory system falls back to keyword recall.
QDRANT_LOCATION=./qdrant_data
# fastembed model name; empty = the multilingual MiniLM default (see embeddings.py).
EMBED_MODEL=

# ── External reflection LLM (Life Engine, later phases) ───────────────────
EXTERNAL_LLM_API_KEY=

# ── Runtime ───────────────────────────────────────────────────────────────
ENV=dev
LOG_LEVEL=INFO
